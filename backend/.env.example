APP_NAME=Stress Research Platform API
APP_ENV=development
API_PREFIX=/api
PORT=8010
MONGODB_URI=mongodb://localhost:27017
# Optional: use when local DNS blocks mongodb+srv SRV lookups.
MONGODB_DIRECT_URI=
MONGODB_DATABASE=stress_research_platform
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
CONSENT_VERSION=1.0
BOOTSTRAP_SUPER_ADMIN_EMAIL=researcher@example.test
BOOTSTRAP_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_SUPER_ADMIN_NAME=Research Administrator
FRONTEND_URL=http://localhost:5173
MOBILE_URL=http://localhost:5174
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Stress Research Platform
DNS_SERVERS=8.8.8.8,1.1.1.1
